// ==============================================
// HOSPIBOT DATABASE SCHEMA
// Multi-tenant healthcare SaaS platform
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==============================================
// ENUMS
// ==============================================

enum TenantType {
  HOSPITAL
  CLINIC
  DOCTOR
  DIAGNOSTIC_CENTER
  IVF_CENTER
  PHARMACY
  HOME_HEALTHCARE
  EQUIPMENT_VENDOR
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum PlanType {
  STARTER
  GROWTH
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN     // Platform-level admin
  TENANT_ADMIN    // Hospital/clinic admin
  BRANCH_ADMIN    // Branch-level admin
  DOCTOR
  RECEPTIONIST
  BILLING_STAFF
  MARKETING_USER
  LAB_TECHNICIAN
  PHARMACIST
  NURSE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentType {
  SCHEDULED
  WALK_IN
  EMERGENCY
  TELECONSULT
  FOLLOW_UP
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  CASH
  WHATSAPP_PAY
  INSURANCE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum LeadStage {
  NEW
  CONTACTED
  APPOINTMENT_BOOKED
  VISITED
  FOLLOW_UP_PENDING
  ACTIVE_PATIENT
  DORMANT
  LOST
}

enum LeadSource {
  WHATSAPP
  WEBSITE
  WALK_IN
  REFERRAL
  GOOGLE_ADS
  FACEBOOK_ADS
  INSTAGRAM
  JUSTDIAL
  PRACTO
  OTHER
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum BedCategory {
  ICU
  SEMI_ICU
  GENERAL
  PRIVATE
  DELUXE
  PEDIATRIC
  MATERNITY
  ISOLATION
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
  HOUSEKEEPING
}

enum AutomationTrigger {
  VISIT_COMPLETED
  DIAGNOSIS_RECORDED
  MEDICATION_PRESCRIBED
  TIME_ELAPSED
  TAG_APPLIED
  APPOINTMENT_CANCELLED
  NO_SHOW
  PAYMENT_RECEIVED
  LAB_REPORT_READY
}

enum AutomationAction {
  SEND_WHATSAPP
  CREATE_APPOINTMENT
  UPDATE_CRM_STAGE
  NOTIFY_STAFF
  SEND_PAYMENT_LINK
  ADD_TAG
  CREATE_TASK
}

enum LabOrderStatus {
  // ── Legacy (clinical portal — still in DB) ──
  PROCESSING     // = old IN_PROGRESS
  COMPLETED      // = old VALIDATED/RESULTED
  // ── Diagnostic 8-stage lifecycle ──
  ORDERED
  SAMPLE_COLLECTED
  DISPATCHED
  RECEIVED_AT_LAB
  IN_PROGRESS
  RESULTED
  VALIDATED
  DELIVERED
  CANCELLED
  REJECTED
}

// ==============================================
// CORE ENTITIES
// ==============================================

model Tenant {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  type            TenantType
  status          TenantStatus  @default(TRIAL)
  plan            PlanType      @default(STARTER)

  // Contact
  email           String
  phone           String
  website         String?

  // Address
  address         String?
  city            String?
  state           String?
  country         String        @default("India")
  pincode         String?

  // WhatsApp
  waPhoneNumberId String?       @map("wa_phone_number_id")
  waBusinessId    String?       @map("wa_business_id")
  waAccessToken   String?       @map("wa_access_token")

  // Portal routing (DB-driven, replaces hardcoded enum routing)
  portalFamilyId  String?       @map("portal_family_id")
  subTypeId       String?       @map("sub_type_id")

  // Branding
  logoUrl         String?       @map("logo_url")
  primaryColor    String        @default("0D7C66")
  settings        Json          @default("{}")

  // Billing
  gstNumber       String?       @map("gst_number")

  // Timestamps
  trialEndsAt     DateTime?     @map("trial_ends_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  // Relations
  portalFamily    PortalFamily?  @relation("TenantPortalFamily", fields: [portalFamilyId], references: [id])
  subType         TenantSubType? @relation("TenantSubType", fields: [subTypeId], references: [id])
  branches        Branch[]
  users           User[]
  departments     Department[]
  patients        Patient[]
  doctors         Doctor[]
  appointments    Appointment[]
  invoices        Invoice[]
  conversations   Conversation[]
  leads           Lead[]
  automationRules AutomationRule[]
  campaigns       Campaign[]
  beds            Bed[]
  labOrders       LabOrder[]

  @@map("tenants")
}

model Branch {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  name        String
  code        String?
  address     String?
  city        String?
  state       String?
  country     String    @default("India")
  pincode     String?
  phone       String?
  email       String?
  timezone    String    @default("Asia/Kolkata")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  departments Department[]
  users       User[]
  appointments Appointment[]
  beds        Bed[]

  @@unique([tenantId, code])
  @@map("branches")
}

model User {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  branchId      String?   @map("branch_id")
  email         String
  phone         String?
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String?   @map("last_name")
  role          UserRole
  avatarUrl     String?   @map("avatar_url")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  permissions   Json      @default("{}") // Granular permission overrides
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  branch        Branch?   @relation(fields: [branchId], references: [id])
  doctor        Doctor?

  @@unique([tenantId, email])
  @@map("users")
}

model Department {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  branchId    String?   @map("branch_id")
  name        String
  code        String?
  type        String?   // clinical, ancillary, administrative
  isActive    Boolean   @default(true) @map("is_active")
  settings    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  branch      Branch?   @relation(fields: [branchId], references: [id])
  doctors     Doctor[]
  appointments Appointment[]

  @@unique([tenantId, branchId, code])
  @@map("departments")
}

model Doctor {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  userId            String    @unique @map("user_id")
  departmentId      String?   @map("department_id")
  registrationNo    String?   @map("registration_no")
  specialties       String[]  @default([])
  qualifications    String?
  experience        Int?      // years
  consultationFee   Int?      @map("consultation_fee") // in paise (INR smallest unit)
  bio               String?
  isAvailable       Boolean   @default(true) @map("is_available")
  slotDuration      Int       @default(15) @map("slot_duration") // minutes
  settings          Json      @default("{}") // working hours, break times, etc.
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  user              User      @relation(fields: [userId], references: [id])
  department        Department? @relation(fields: [departmentId], references: [id])
  appointments      Appointment[]
  prescriptions     Prescription[]

  @@map("doctors")
}

// ==============================================
// PATIENT & HEALTH VAULT
// ==============================================

model Patient {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  healthId        String?   @unique @map("health_id") // HB-XXXXXXXX
  abhaId          String?   @map("abha_id")

  // Demographics
  firstName       String    @map("first_name")
  lastName        String?   @map("last_name")
  phone           String
  email           String?
  dateOfBirth     DateTime? @map("date_of_birth")
  gender          Gender?
  bloodGroup      String?   @map("blood_group")

  // Address
  address         String?
  city            String?
  state           String?
  pincode         String?

  // Medical
  allergies       String[]  @default([])
  chronicConditions String[] @default([]) @map("chronic_conditions")
  currentMedications Json   @default("[]") @map("current_medications")
  emergencyContact Json?    @map("emergency_contact")

  // Insurance
  insuranceProvider String? @map("insurance_provider")
  insurancePolicyNo String? @map("insurance_policy_no")

  // CRM
  tags            String[]  @default([])
  notes           String?
  language        String    @default("en")

  // Timestamps
  lastVisitAt     DateTime? @map("last_visit_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // Relations
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  appointments    Appointment[]
  visits          Visit[]
  invoices        Invoice[]
  conversations   Conversation[]
  leads           Lead[]
  prescriptions   Prescription[]
  labOrders       LabOrder[]
  homeCollections   HomeCollection[]
  dispensingOrders  DispensingOrder[]

  @@unique([tenantId, phone])
  @@index([phone])
  @@index([healthId])
  @@map("patients")
}

model Visit {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  patientId       String    @map("patient_id")
  appointmentId   String?   @map("appointment_id")
  doctorId        String?   @map("doctor_id")

  // Clinical
  chiefComplaint  String?   @map("chief_complaint")
  vitals          Json      @default("{}") // BP, pulse, temp, SpO2, weight, height
  diagnosisCodes  String[]  @default([]) @map("diagnosis_codes") // ICD-10
  diagnosisText   String?   @map("diagnosis_text")
  clinicalNotes   String?   @map("clinical_notes")
  treatmentPlan   String?   @map("treatment_plan")
  followUpDays    Int?      @map("follow_up_days")

  // Metadata
  visitType       String?   @map("visit_type") // OPD, IPD, Emergency
  source          String?   // dictation, manual, imported

  // Patient feedback / NPS
  rating          Int?      // 1-5 star rating
  feedback        String?   // Patient comment
  npsScore        Int?      @map("nps_score") // 0-10 NPS
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  patient         Patient   @relation(fields: [patientId], references: [id])
  prescriptions   Prescription[]
  invoices        Invoice[]

  @@map("visits")
}

model Prescription {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  patientId       String    @map("patient_id")
  doctorId        String    @map("doctor_id")
  visitId         String?   @map("visit_id")

  medications     Json      @default("[]") // [{name, generic, dosage, frequency, duration, route, instructions}]
  notes           String?
  pdfUrl          String?   @map("pdf_url")
  refillDueDate   DateTime? @map("refill_due_date")
  isActive        Boolean   @default(true) @map("is_active")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  patient         Patient   @relation(fields: [patientId], references: [id])
  doctor          Doctor    @relation(fields: [doctorId], references: [id])
  visit           Visit?    @relation(fields: [visitId], references: [id])

  @@map("prescriptions")
}

// ==============================================
// APPOINTMENTS & QUEUE
// ==============================================

model Appointment {
  id              String            @id @default(uuid())
  tenantId        String            @map("tenant_id")
  branchId        String?           @map("branch_id")
  patientId       String            @map("patient_id")
  doctorId        String            @map("doctor_id")
  departmentId    String?           @map("department_id")

  type            AppointmentType   @default(SCHEDULED)
  status          AppointmentStatus @default(PENDING)
  tokenNumber     String?           @map("token_number")

  scheduledAt     DateTime          @map("scheduled_at")
  duration        Int               @default(15) // minutes
  checkedInAt     DateTime?         @map("checked_in_at")
  startedAt       DateTime?         @map("started_at")
  completedAt     DateTime?         @map("completed_at")
  cancelledAt     DateTime?         @map("cancelled_at")
  cancelReason    String?           @map("cancel_reason")

  notes           String?
  source          String?           // whatsapp, web, walk-in, phone

  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  branch          Branch?           @relation(fields: [branchId], references: [id])
  patient         Patient           @relation(fields: [patientId], references: [id])
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  department      Department?       @relation(fields: [departmentId], references: [id])

  @@index([tenantId, scheduledAt])
  @@index([doctorId, scheduledAt])
  @@map("appointments")
}

// ==============================================
// BILLING & PAYMENTS
// ==============================================

model Invoice {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  patientId       String        @map("patient_id")
  visitId         String?       @map("visit_id")
  invoiceNumber   String        @map("invoice_number")

  items           Json          @default("[]") // [{description, qty, rate, amount, department, gstRate}]
  subtotal        Int           @default(0) // paise
  gstAmount       Int           @default(0) @map("gst_amount")
  discount        Int           @default(0)
  totalAmount     Int           @default(0) @map("total_amount")
  paidAmount      Int           @default(0) @map("paid_amount")
  dueAmount       Int           @default(0) @map("due_amount")

  status          InvoiceStatus @default(DRAFT)
  dueDate         DateTime?     @map("due_date")
  pdfUrl          String?       @map("pdf_url")
  notes           String?

  // Insurance / TPA fields
  insuranceProvider   String?   @map("insurance_provider")
  insurancePolicyNo   String?   @map("insurance_policy_no")
  tpaName             String?   @map("tpa_name")
  preAuthNumber       String?   @map("pre_auth_number")
  preAuthStatus       String?   @map("pre_auth_status")  // PENDING | APPROVED | REJECTED
  preAuthAmount       Int?      @map("pre_auth_amount")   // paise
  claimNumber         String?   @map("claim_number")
  claimStatus         String?   @map("claim_status")      // DRAFT | SUBMITTED | PROCESSING | APPROVED | REJECTED | SETTLED
  claimAmount         Int?      @map("claim_amount")       // paise
  settledAmount       Int?      @map("settled_amount")     // paise
  claimSubmittedAt    DateTime? @map("claim_submitted_at")
  claimSettledAt      DateTime? @map("claim_settled_at")
  isTpaBill           Boolean   @default(false) @map("is_tpa_bill")

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  patient         Patient       @relation(fields: [patientId], references: [id])
  visit           Visit?        @relation(fields: [visitId], references: [id])
  payments        Payment[]

  @@unique([tenantId, invoiceNumber])
  @@map("invoices")
}

model Payment {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  invoiceId       String        @map("invoice_id")
  amount          Int           // paise
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)

  gatewayOrderId  String?       @map("gateway_order_id")
  gatewayPaymentId String?     @map("gateway_payment_id")
  gatewaySignature String?     @map("gateway_signature")

  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  invoice         Invoice       @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

// ==============================================
// WHATSAPP & CONVERSATIONS
// ==============================================

model Conversation {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  patientId       String?   @map("patient_id")
  waContactPhone  String    @map("wa_contact_phone")
  waContactName   String?   @map("wa_contact_name")

  assignedTo      String?   @map("assigned_to") // userId
  department      String?
  isBot           Boolean   @default(true) @map("is_bot") // bot handling or human
  isClosed        Boolean   @default(false) @map("is_closed")

  lastMessageAt   DateTime? @map("last_message_at")
  messageCount    Int       @default(0) @map("message_count")
  unreadCount     Int       @default(0) @map("unread_count")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  patient         Patient?  @relation(fields: [patientId], references: [id])
  messages        Message[]

  @@unique([tenantId, waContactPhone])
  @@map("conversations")
}

model Message {
  id              String           @id @default(uuid())
  conversationId  String           @map("conversation_id")
  direction       MessageDirection
  content         String?
  mediaUrl        String?          @map("media_url")
  mediaType       String?          @map("media_type") // image, document, audio, video
  templateName    String?          @map("template_name")

  waMessageId     String?          @unique @map("wa_message_id")
  status          MessageStatus    @default(QUEUED)

  senderType      String?          @map("sender_type") // patient, bot, staff
  senderUserId    String?          @map("sender_user_id")

  createdAt       DateTime         @default(now()) @map("created_at")

  conversation    Conversation     @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ==============================================
// CRM & LEADS
// ==============================================

model Lead {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  patientId       String?   @map("patient_id")

  name            String?
  phone           String
  email           String?

  source          LeadSource @default(WHATSAPP)
  stage           LeadStage  @default(NEW)
  campaignId      String?    @map("campaign_id")

  assignedTo      String?    @map("assigned_to") // userId
  tags            String[]   @default([])
  notes           String?
  score           Int        @default(0)

  lastContactAt   DateTime?  @map("last_contact_at")
  convertedAt     DateTime?  @map("converted_at")
  lostReason      String?    @map("lost_reason")

  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  patient         Patient?   @relation(fields: [patientId], references: [id])
  campaign        Campaign?  @relation(fields: [campaignId], references: [id])

  @@index([tenantId, stage])
  @@map("leads")
}

model Campaign {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  name            String
  templateName    String    @map("template_name")
  filters         Json      @default("{}") // {tags, lastVisitBefore, diagnosisCodes, etc.}

  // Stats
  targetCount     Int       @default(0) @map("target_count")
  sentCount       Int       @default(0) @map("sent_count")
  deliveredCount  Int       @default(0) @map("delivered_count")
  readCount       Int       @default(0) @map("read_count")
  respondedCount  Int       @default(0) @map("responded_count")
  convertedCount  Int       @default(0) @map("converted_count")

  scheduledAt     DateTime? @map("scheduled_at")
  executedAt      DateTime? @map("executed_at")
  status          String    @default("draft") // draft, scheduled, executing, completed, cancelled

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  leads           Lead[]

  @@map("campaigns")
}

// ==============================================
// AUTOMATION / REVENUE ENGINE
// ==============================================

model AutomationRule {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  name            String
  description     String?
  isActive        Boolean   @default(true) @map("is_active")

  trigger         AutomationTrigger
  conditions      Json      @default("{}") // {diagnosisCodes, tags, ageRange, etc.}
  waitDays        Int       @default(30) @map("wait_days")
  actions         Json      @default("[]") // [{type, template, message, etc.}]
  escalation      Json      @default("{}") // {retryAfterDays, maxRetries, escalateTo}

  // Stats
  triggeredCount  Int       @default(0) @map("triggered_count")
  convertedCount  Int       @default(0) @map("converted_count")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  logs            AutomationLog[]

  @@map("automation_rules")
}

model AutomationLog {
  id              String    @id @default(uuid())
  ruleId          String    @map("rule_id")
  patientId       String    @map("patient_id")
  tenantId        String    @map("tenant_id")

  actionTaken     String    @map("action_taken")
  result          String?   // sent, booked, no_response, failed
  responseAt      DateTime? @map("response_at")

  executedAt      DateTime  @default(now()) @map("executed_at")

  rule            AutomationRule @relation(fields: [ruleId], references: [id])

  @@index([ruleId, executedAt])
  @@map("automation_logs")
}

// ==============================================
// BED MANAGEMENT
// ==============================================

model Bed {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  branchId        String      @map("branch_id")

  ward            String
  number          String
  category        BedCategory @default(GENERAL)
  status          BedStatus   @default(AVAILABLE)

  patientId       String?     @map("patient_id")
  admittedAt      DateTime?   @map("admitted_at")
  expectedDischarge DateTime? @map("expected_discharge")

  dailyRate       Int         @default(0) @map("daily_rate") // paise
  notes           String?

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  branch          Branch      @relation(fields: [branchId], references: [id])

  @@unique([tenantId, branchId, ward, number])
  @@map("beds")
}

// ==============================================
// LAB & DIAGNOSTICS
// ==============================================

model LabOrder {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  branchId        String?        @map("branch_id")
  patientId       String         @map("patient_id")
  doctorId        String?        @map("doctor_id")
  orderNumber     String         @map("order_number")

  // Legacy JSON tests field (kept for backward compat with existing data)
  tests           Json           @default("[]")
  // New 8-stage status aligned with blueprint
  status          LabOrderStatus @default(ORDERED)

  // Extended order fields
  collectionMode  String         @default("WALKIN") @map("collection_mode")   // WALKIN|HOME_COLLECTION|EXTERNAL
  referringDoctor String?        @map("referring_doctor")
  referringDoctorCrmId String?   @map("referring_doctor_crm_id")
  corporateClientId String?      @map("corporate_client_id")
  clinicalInfo    String?        @map("clinical_info")
  isStat          Boolean        @default(false) @map("is_stat")
  isAfterHours    Boolean        @default(false) @map("is_after_hours")
  version         Int            @default(1)
  statPremium     Int            @default(0) @map("stat_premium")   // paise

  // Sample barcode (primary barcode for the order)
  sampleBarcode   String?        @map("sample_barcode")

  // Financial
  totalAmount     Int            @default(0) @map("total_amount")   // paise
  paidAmount      Int            @default(0) @map("paid_amount")    // paise

  // Timestamps
  sampleCollectedAt DateTime?    @map("sample_collected_at")
  dispatchedAt    DateTime?      @map("dispatched_at")
  receivedAtLabAt DateTime?      @map("received_at_lab_at")
  reportedAt      DateTime?      @map("reported_at")
  releasedAt      DateTime?      @map("released_at")

  // Legacy report fields (kept for backward compat)
  reportUrl       String?        @map("report_url")
  reportDelivered Boolean        @default(false) @map("report_delivered")
  waSent          Boolean        @default(false) @map("wa_sent")

  remarks         String?
  notes           String?
  priority        String         @default("normal")   // normal, urgent, stat

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  patient         Patient        @relation(fields: [patientId], references: [id])

  // New normalized relations
  orderItems      OrderItem[]
  samples         Sample[]
  diagnosticReports DiagnosticReport[]
  criticalAlerts  CriticalValueAlert[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([patientId])
  @@map("lab_orders")
}

// ==============================================
// COMPLIANCE — Sprint 3 Regulatory Hard-Blocks
// ==============================================
// These surfaces enforce Indian regulatory compliance for diagnostic
// operations. The `ComplianceService.assertCanReleaseReport` method is
// called from `DiagnosticService.signAndRelease` to block final report
// release if any applicable compliance guard fails.
//
// Laws referenced:
//   PcpndtFormF             — PC-PNDT Act, 1994 (prenatal imaging)
//   AerbDoseEntry           — Atomic Energy (Radiation Protection) Rules 2004
//   PregnancyScreening      — PC-PNDT Act sex-determination safeguards
//   MammographyOperatorLog  — AERB Mammography Guidelines
//   BmwWasteLog             — Bio-Medical Waste Management Rules 2016
//   BiosafetyChecklist      — ICMR Biosafety Guidelines (BSL-2 labs)

model PcpndtFormF {
  id                         String    @id @default(uuid())
  tenantId                   String    @map("tenant_id")
  labOrderId                 String?   @map("lab_order_id")
  patientId                  String    @map("patient_id")

  // Form F mandatory fields per PC-PNDT Act
  formFNumber                String    @map("form_f_number")
  referringDoctorName        String    @map("referring_doctor_name")
  referringDoctorRegNo       String    @map("referring_doctor_reg_no")
  performedByDoctorName      String    @map("performed_by_doctor_name")
  performedByDoctorRegNo     String    @map("performed_by_doctor_reg_no")

  gestationalAgeWeeks        Int?      @map("gestational_age_weeks")
  indicationForScan          String    @map("indication_for_scan")
  scanType                   String    @map("scan_type")      // USG, fetal-MRI, etc.
  findings                   String?
  informedConsentTaken       Boolean   @default(false) @map("informed_consent_taken")

  // Monthly submission tracking
  submittedToAuthority       Boolean   @default(false) @map("submitted_to_authority")
  submittedAt                DateTime? @map("submitted_at")

  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt       @map("updated_at")

  @@unique([tenantId, formFNumber])
  @@index([tenantId, labOrderId])
  @@index([tenantId, patientId])
  @@index([tenantId, submittedToAuthority, createdAt])
  @@map("pcpndt_form_f")
}

model AerbDoseEntry {
  id                         String    @id @default(uuid())
  tenantId                   String    @map("tenant_id")
  labOrderId                 String?   @map("lab_order_id")
  patientId                  String?   @map("patient_id")
  equipmentId                String?   @map("equipment_id")

  examDate                   DateTime  @map("exam_date")
  examType                   String    @map("exam_type")       // XRAY | CT | MAMMO | NUCLEAR_MEDICINE | FLUORO
  doseMSv                    Float     @map("dose_msv")        // radiation dose delivered
  operatorUserId             String    @map("operator_user_id")
  operatorTldBadgeReading    Float?    @map("operator_tld_badge_reading") // personal dosimeter mSv

  notes                      String?
  createdAt                  DateTime  @default(now()) @map("created_at")

  @@index([tenantId, labOrderId])
  @@index([tenantId, examDate])
  @@index([tenantId, equipmentId, examDate])
  @@index([tenantId, operatorUserId, examDate])
  @@map("aerb_dose_entries")
}

model PregnancyScreening {
  id                                  String    @id @default(uuid())
  tenantId                            String    @map("tenant_id")
  patientId                           String    @map("patient_id")
  labOrderId                          String?   @map("lab_order_id")

  screenedAt                          DateTime  @default(now()) @map("screened_at")
  gestationalAgeWeeks                 Int?      @map("gestational_age_weeks")

  // PC-PNDT safeguards
  hasConsentForm                      Boolean   @default(false) @map("has_consent_form")
  sexDeterminationDeclarationSigned   Boolean   @default(false) @map("sex_determination_declaration_signed")
  flaggedForReview                    Boolean   @default(false) @map("flagged_for_review")

  screenedByUserId                    String    @map("screened_by_user_id")
  notes                               String?
  createdAt                           DateTime  @default(now()) @map("created_at")

  @@index([tenantId, labOrderId])
  @@index([tenantId, patientId, screenedAt])
  @@index([tenantId, flaggedForReview])
  @@map("pregnancy_screenings")
}

model MammographyOperatorLog {
  id                         String    @id @default(uuid())
  tenantId                   String    @map("tenant_id")
  operatorUserId             String    @map("operator_user_id")

  certificationNumber        String    @map("certification_number")
  certificationExpiresAt     DateTime  @map("certification_expires_at")

  // Daily QC (phantom scan)
  dailyQcDate                DateTime  @map("daily_qc_date")
  dailyQcPassed              Boolean   @default(false) @map("daily_qc_passed")
  phantomImageScore          Int?      @map("phantom_image_score") // 0–100

  notes                      String?
  createdAt                  DateTime  @default(now()) @map("created_at")

  @@index([tenantId, operatorUserId, dailyQcDate])
  @@index([tenantId, certificationExpiresAt])
  @@map("mammography_operator_logs")
}

model BmwWasteLog {
  id                         String    @id @default(uuid())
  tenantId                   String    @map("tenant_id")
  branchId                   String?   @map("branch_id")

  logDate                    DateTime  @map("log_date")

  // Category-wise weight in kilograms (BMW Rules 2016)
  yellowBagKg                Float     @default(0) @map("yellow_bag_kg")  // anatomical, contaminated
  redBagKg                   Float     @default(0) @map("red_bag_kg")     // plastic, contaminated
  whiteBagKg                 Float     @default(0) @map("white_bag_kg")   // sharps
  blueBagKg                  Float     @default(0) @map("blue_bag_kg")    // glass, metal

  authorizedDisposerName     String    @map("authorized_disposer_name")
  authorizedDisposerReceipt  String    @map("authorized_disposer_receipt") // CPCB authorized vendor receipt no.

  loggedByUserId             String    @map("logged_by_user_id")
  notes                      String?
  createdAt                  DateTime  @default(now()) @map("created_at")

  @@unique([tenantId, branchId, logDate])
  @@index([tenantId, logDate])
  @@map("bmw_waste_logs")
}

model BiosafetyChecklist {
  id                                  String    @id @default(uuid())
  tenantId                            String    @map("tenant_id")
  branchId                            String?   @map("branch_id")

  checklistDate                       DateTime  @map("checklist_date")

  // ICMR BSL-2 mandatory items
  bsc2CertCurrentWithin12Mo           Boolean   @default(false) @map("bsc2_cert_current_within_12mo")
  ppeInventoryAdequate                Boolean   @default(false) @map("ppe_inventory_adequate")
  spillKitsAvailable                  Boolean   @default(false) @map("spill_kits_available")
  eyewashStationFunctional            Boolean   @default(false) @map("eyewash_station_functional")
  autoclaveSporeTestPassedWithin30D   Boolean   @default(false) @map("autoclave_spore_test_passed_within_30d")
  trainingLogCurrent                  Boolean   @default(false) @map("training_log_current")

  // Aggregate — true only if ALL above are true
  passed                              Boolean   @default(false)
  notes                               String?

  completedByUserId                   String    @map("completed_by_user_id")
  createdAt                           DateTime  @default(now()) @map("created_at")

  @@index([tenantId, checklistDate])
  @@index([tenantId, passed, checklistDate])
  @@map("biosafety_checklists")
}

