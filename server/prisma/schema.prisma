  slug          String    @unique        // "clinical", "diagnostic", etc.
  description   String                  // shown on registration card
  icon          String                  // Lucide icon name
  sortOrder     Int       @default(0)   @map("sort_order")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt    @map("updated_at")

  subTypes      TenantSubType[]
  theme         PortalTheme?
  tenants       Tenant[]       @relation("TenantPortalFamily")

  @@map("portal_families")
}

model TenantSubType {
  id              String    @id @default(uuid())
  portalFamilyId  String    @map("portal_family_id")
  name            String
  slug            String                // unique within family
  description     String?
  icon            String?               // Lucide icon name
  // Operational group within the portal family (e.g. "collection", "pathology", "imaging").
  // Nullable because Clinical / Pharmacy / etc. portals don't use groups yet.
  groupSlug       String?   @map("group_slug")
  // Short (2-3 line) operational description shown on the subtype-picker card.
  subtypeTagline  String?   @map("subtype_tagline")
  // Typical daily volume string e.g. "30–500 samples/day" — shown on the card.
  volumeHint      String?   @map("volume_hint")
  featureFlags    Json      @default("{}") @map("feature_flags")
  // e.g. { appointments: true, inventory: false, labReports: true, ... }
  regFields       Json      @default("{}") @map("reg_fields")
  // extra registration fields: { drugLicense: true, nablNo: false, ... }
  sortOrder       Int       @default(0) @map("sort_order")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  portalFamily    PortalFamily @relation(fields: [portalFamilyId], references: [id])
  tenants         Tenant[]     @relation("TenantSubType")

  @@unique([portalFamilyId, slug])
  @@index([portalFamilyId, groupSlug])
  @@map("tenant_sub_types")
}

// ──────────────────────────────────────────────────────────────────────────────
// Subtype groups — operational categories inside a portal family
