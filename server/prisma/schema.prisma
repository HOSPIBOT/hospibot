  upperNormal    Float?   @map("upper_normal")
  lowerCritical  Float?   @map("lower_critical")
  upperCritical  Float?   @map("upper_critical")
  unit           String?
  interpretation String?  // text guide for pathologist
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([tenantId, testCode])
  @@map("reference_ranges")
}

// ── Result Entry ─────────────────────────────────────────────────────────

model ResultEntry {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  orderItemId     String      @map("order_item_id")
  labOrderId      String      @map("lab_order_id")
  numericValue    Float?      @map("numeric_value")
  textValue       String?     @map("text_value")
  unit            String?
  flag            ResultFlag  @default(NORMAL)
  lowerNormal     Float?      @map("lower_normal")
  upperNormal     Float?      @map("upper_normal")
  lowerCritical   Float?      @map("lower_critical")
  upperCritical   Float?      @map("upper_critical")
  interpretation  String?     // pathologist comment
  isDraft         Boolean     @default(true) @map("is_draft")
  enteredBy       String?     @map("entered_by")
  enteredAt       DateTime?   @map("entered_at")
  validatedBy     String?     @map("validated_by")
  validatedAt     DateTime?   @map("validated_at")
  signedBy        String?     @map("signed_by")
  signedAt        DateTime?   @map("signed_at")
  version         Int         @default(1)
  amendReason     String?     @map("amend_reason")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  orderItem       OrderItem   @relation(fields: [orderItemId], references: [id])
  criticalAlerts  CriticalValueAlert[]

  @@index([orderItemId])
  @@index([labOrderId])
  @@map("result_entries")
}

// ── Critical Value Alerts ─────────────────────────────────────────────────

model CriticalValueAlert {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  resultEntryId   String    @map("result_entry_id")
  labOrderId      String    @map("lab_order_id")
  patientId       String    @map("patient_id")
  doctorId        String?   @map("doctor_id")
  testCode        String    @map("test_code")
  testName        String    @map("test_name")
  criticalValue   String    @map("critical_value")
  threshold       String
  alertSentAt     DateTime? @map("alert_sent_at")
  acknowledgedBy  String?   @map("acknowledged_by")
  acknowledgedAt  DateTime? @map("acknowledged_at")
  escalatedTo     String?   @map("escalated_to")
  escalatedAt     DateTime? @map("escalated_at")
  smsFallbackSent Boolean   @default(false) @map("sms_fallback_sent")
  createdAt       DateTime  @default(now()) @map("created_at")

  resultEntry     ResultEntry @relation(fields: [resultEntryId], references: [id])
  labOrder        LabOrder    @relation(fields: [labOrderId], references: [id])

  @@index([labOrderId])
  @@index([tenantId])
  @@map("critical_value_alerts")
}

