  testId        String?     @map("test_id")        // FK to TestCatalog
  testCode      String      @map("test_code")
  testName      String      @map("test_name")
  department    String?
  status        SampleStatus @default(REGISTERED)
  isOutsourced  Boolean     @default(false) @map("is_outsourced")
  outsourcedTo  String?     @map("outsourced_to")  // reference lab name
  isStat        Boolean     @default(false) @map("is_stat")
  tatDeadline   DateTime?   @map("tat_deadline")
  price         Int         @default(0)            // in paise
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  labOrder      LabOrder    @relation(fields: [labOrderId], references: [id])
  resultEntries ResultEntry[]

  @@index([labOrderId])
  @@index([tenantId, status])
  @@map("order_items")
}

// ── Sample Tracking ───────────────────────────────────────────────────────

model Sample {
  id                String      @id @default(uuid())
  tenantId          String      @map("tenant_id")
  labOrderId        String      @map("lab_order_id")
  barcode           String      @unique
  tubeType          String?     @map("tube_type")   // EDTA, Plain, Fluoride, Urine
