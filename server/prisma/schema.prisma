  toStatus    String      @map("to_status")
  userId      String?     @map("user_id")
  notes       String?
  location    String?
  createdAt   DateTime    @default(now()) @map("created_at")

  sample      Sample      @relation(fields: [sampleId], references: [id])

  @@index([sampleId])
  @@map("sample_status_logs")
}

// ── Reference Ranges ─────────────────────────────────────────────────────

model ReferenceRange {
