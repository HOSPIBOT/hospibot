// ==============================================
// PHARMACY — PRODUCT CATALOGUE
// ==============================================

model PharmacyProduct {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")

  // Drug identity
  name              String                        // Brand name
  genericName       String?  @map("generic_name")
  manufacturer      String?
  category          String   @default("General")  // Tablet, Capsule, Syrup, Injection, etc.
  composition       String?                       // Active ingredients
  strength          String?                       // 500mg, 10mg/5ml, etc.
  form              String   @default("Tablet")   // Tablet, Capsule, Syrup, Injection, Cream, Drops
  schedule          String?                       // H, H1, X (drug schedule)
  hsCode            String?  @map("hs_code")      // HS code for GST

  // Pricing
  mrp               Int      @map("mrp")          // paise — Maximum Retail Price
  costPrice         Int      @default(0) @map("cost_price") // paise
  sellingPrice      Int      @map("selling_price") // paise
  gstRate           Float    @default(12)          @map("gst_rate")

  // Stock
  currentStock      Int      @default(0) @map("current_stock")   // units
  minimumStock      Int      @default(10) @map("minimum_stock")  // reorder level
  unit              String   @default("Strip")                    // Strip, Bottle, Vial, Tube
  unitsPerPack      Int      @default(10) @map("units_per_pack")
  storageCondition  String?  @map("storage_condition")           // Cool & Dry, Refrigerate, etc.

  isActive          Boolean  @default(true) @map("is_active")
  requiresPrescription Boolean @default(false) @map("requires_prescription")
  isControlledSubstance Boolean @default(false) @map("is_controlled_substance")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  batches           PharmacyBatch[]
  dispensingItems   DispensingItem[]

  @@unique([tenantId, name, strength])
  @@index([tenantId, category])
  @@map("pharmacy_products")
}

// Batch tracking for expiry management
model PharmacyBatch {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  productId    String   @map("product_id")
  batchNumber  String   @map("batch_number")
  expiryDate   DateTime @map("expiry_date")
  quantity     Int                            // units received
  remaining    Int                            // units left
  costPrice    Int      @map("cost_price")    // paise per unit
  sellingPrice Int      @map("selling_price") // paise per unit
  supplierId   String?  @map("supplier_id")
  purchaseOrderId String? @map("purchase_order_id")
  receivedAt   DateTime @default(now()) @map("received_at")

  product PharmacyProduct @relation(fields: [productId], references: [id])

  @@index([tenantId, productId, expiryDate])
  @@map("pharmacy_batches")
}

