  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([portalFamilyId, slug])
  @@map("subtype_groups")
}

// ──────────────────────────────────────────────────────────────────────────────
// Registration drafts — persist the multi-step registration wizard state so
