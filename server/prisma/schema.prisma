  coldChainRequired Boolean     @default(false) @map("cold_chain_required")
  storageLocation   String?     @map("storage_location") // rack-shelf-position
  retainUntil       DateTime?   @map("retain_until")
  disposedAt        DateTime?   @map("disposed_at")
  photoUrl          String?     @map("photo_url")   // agent uploads tube photo
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  labOrder          LabOrder    @relation(fields: [labOrderId], references: [id])
  statusLogs        SampleStatusLog[]

  @@index([labOrderId])
  @@index([barcode])
  @@index([tenantId, status])
