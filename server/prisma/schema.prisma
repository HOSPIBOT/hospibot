model CultureTracking {
  id                  String    @id @default(uuid())
  tenantId            String    @map("tenant_id")
  labOrderId          String?   @map("lab_order_id")
  patientId           String?   @map("patient_id")
  specimenType        String    @map("specimen_type")       // blood | urine | wound | sputum | stool | csf | other
  specimenSource      String?   @map("specimen_source")     // e.g. "left arm blood culture"
  cultureMedia        String    @map("culture_media")       // blood_agar | mac_conkey | chocolate | sabouraud | bactec | other
  inoculatedAt        DateTime  @map("inoculated_at")
  readAt              DateTime? @map("read_at")
  growthStatus        String    @default("INCUBATING")      // INCUBATING | NO_GROWTH | GROWTH_DETECTED | IDENTIFIED | FINAL
  organismIdentified  String?   @map("organism_identified") // e.g. "E. coli", "MRSA", "Candida albicans"
  colonyCount         String?   @map("colony_count")        // e.g. ">10^5 CFU/ml"
  incubationHours     Int?      @map("incubation_hours")
  isFlaggedMdro       Boolean   @default(false) @map("is_flagged_mdro") // MRSA, VRE, ESBL, CRE
  technicianUserId    String    @map("technician_user_id")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt      @map("updated_at")

  @@index([tenantId, growthStatus])
  @@index([tenantId, inoculatedAt])
  @@map("culture_trackings")
}

// ==============================================
// BLOOD DONOR REGISTRY — NACO / D&C Act compliant
// Fields per: NACO Standards for Blood Banks & BTS,
// Drugs & Cosmetics Rules 1945 Schedule F Part XII-B,
// Supreme Court PIL Common Cause vs UoI (1996)
// ==============================================

model BloodDonor {
  id                    String    @id @default(uuid())
  tenantId              String    @map("tenant_id")
  // ── Identity (NACO donor record) ──
  fullName              String    @map("full_name")
  dateOfBirth           DateTime? @map("date_of_birth")
  age                   Int                                 // 18–65 per NACO
  gender                String                              // MALE | FEMALE
  phone                 String
  address               String?
  idProofType           String?   @map("id_proof_type")     // AADHAAR | VOTER_ID | PAN | DRIVING_LICENSE | PASSPORT
  idProofNumber         String?   @map("id_proof_number")
  // ── Blood group (ABO + Rh, mandatory) ──
  bloodGroup            String    @map("blood_group")       // A | B | AB | O
  rhFactor              String    @map("rh_factor")         // POSITIVE | NEGATIVE
  // ── Medical screening (NACO eligibility criteria) ──
  weightKg              Float     @map("weight_kg")         // ≥45 kg
  hemoglobinGdl         Float     @map("hemoglobin_gdl")    // ≥12.5 g/dL
  bpSystolic            Int       @map("bp_systolic")       // 100–180 mmHg
  bpDiastolic           Int       @map("bp_diastolic")      // 50–100 mmHg
  pulseRate             Int       @map("pulse_rate")        // 60–100 bpm, regular
  // ── Donor classification (D&C Rules — mandatory on label) ──
  donorType             String    @map("donor_type")        // VOLUNTARY | REPLACEMENT (paid BANNED per SC 1996)
  // ── Eligibility (computed server-side per NACO criteria) ──
  isEligible            Boolean   @map("is_eligible")
  ineligibilityReason   String?   @map("ineligibility_reason")
  // ── Deferral (NACO deferral criteria) ──
  isDeferredNow         Boolean   @default(false)  @map("is_deferred_now")
  deferralReason        String?   @map("deferral_reason")   // malaria_3mo | jaundice_1yr | tattoo_6mo | surgery_12mo | pregnancy_6mo | rabies_vaccine_1yr | other
  deferredUntil         DateTime? @map("deferred_until")
  // ── Donation tracking ──
  totalDonations        Int       @default(0) @map("total_donations")
  lastDonationDate      DateTime? @map("last_donation_date")
  // ── Medical officer fitness certification ──
  certifiedByName       String?   @map("certified_by_name")
  certifiedByRegNo      String?   @map("certified_by_reg_no")
  // ── Metadata ──
  registeredByUserId    String    @map("registered_by_user_id")
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt      @map("updated_at")

  @@index([tenantId, bloodGroup, rhFactor])
  @@index([tenantId, phone])
  @@index([tenantId, isDeferredNow])
  @@map("blood_donors")
}

// ==============================================
// CROSSMATCH REGISTER — D&C Rules Schedule F Part XII-B
// NACO Standards: ABO compatibility + antiglobulin test
// ==============================================

model CrossmatchRecord {
  id                    String    @id @default(uuid())
  tenantId              String    @map("tenant_id")
  // ── Issue register fields (D&C Rules mandatory) ──
  serialNumber          String    @map("serial_number")     // auto-generated sequential
  requestDate           DateTime  @map("request_date")
  issuedAt              DateTime? @map("issued_at")
  // ── Donor unit details ──
  bagSerialNumber       String    @map("bag_serial_number")
  donorBloodGroup       String    @map("donor_blood_group") // A | B | AB | O
  donorRhFactor         String    @map("donor_rh_factor")   // POSITIVE | NEGATIVE
  quantityMl            Int       @map("quantity_ml")
  componentType         String    @map("component_type")    // WHOLE_BLOOD | PRBC | FFP | PLATELETS | CRYO
  // ── Recipient details (D&C Rules mandatory) ──
  recipientName         String    @map("recipient_name")
  recipientBloodGroup   String    @map("recipient_blood_group")
  recipientRhFactor     String    @map("recipient_rh_factor")
  recipientHospital     String?   @map("recipient_hospital")
  recipientWard         String?   @map("recipient_ward")
  indicationForTransfusion String @map("indication_for_transfusion") // surgical | medical | obstetric | emergency | exchange_transfusion
  // ── Crossmatch test results (NACO: ABO + antiglobulin) ──
  immediateSpinResult   String    @map("immediate_spin_result")     // COMPATIBLE | INCOMPATIBLE
  iatCoombsResult       String?   @map("iat_coombs_result")         // COMPATIBLE | INCOMPATIBLE | NOT_DONE
  antibodyScreenResult  String?   @map("antibody_screen_result")    // NEGATIVE | POSITIVE
  antibodyIdentified    String?   @map("antibody_identified")       // e.g. "Anti-Kell", "Anti-Duffy-a"
  // ── Final compatibility ──
  finalResult           String    @map("final_result")              // COMPATIBLE | INCOMPATIBLE | LEAST_INCOMPATIBLE
  // ── Personnel ──
  testedByUserId        String    @map("tested_by_user_id")
  issuedByName          String?   @map("issued_by_name")
  medicalOfficerName    String?   @map("medical_officer_name")
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt      @map("updated_at")

  @@unique([tenantId, serialNumber])
  @@index([tenantId, requestDate])
  @@index([tenantId, recipientName])
  @@map("crossmatch_records")
}

// ==============================================
// AUDIT LOG
