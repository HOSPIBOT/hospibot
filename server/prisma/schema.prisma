enum SampleStatus {
  REGISTERED
  COLLECTED
  DISPATCHED
  RECEIVED
  IN_PROGRESS
  RESULTED
  VALIDATED
  RELEASED
  REJECTED
}

enum ResultFlag {
  NORMAL
  LOW
  HIGH
  CRITICAL_LOW
  CRITICAL_HIGH
  TEXT
  ABNORMAL
}

enum CollectionMode {
  WALKIN
  HOME_COLLECTION
  EXTERNAL
}

enum DeliveryChannel {
  WHATSAPP
  SMS
  EMAIL
  DOWNLOAD
}

enum WalletType {
  SUBSCRIPTION
  WHATSAPP
  SMS
  STORAGE
}

enum WalletTxType {
  CREDIT_TOPUP
  CREDIT_PLAN_ALLOCATION
  DEBIT_USAGE
  DEBIT_RENEWAL
  DEBIT_ADJUSTMENT
  REFUND
}

// ── Order Items (individual test per order) ───────────────────────────────

model OrderItem {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
