  hrContactMobile String    @map("hr_contact_mobile")
  hrContactEmail  String?   @map("hr_contact_email")
  rateCardId      String?   @map("rate_card_id")
  creditLimit     Int       @default(0) @map("credit_limit") // paise
  creditDays      Int       @default(30) @map("credit_days")
  contractExpiry  DateTime? @map("contract_expiry")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("corporate_clients")
}

// ── Reagent Inventory ─────────────────────────────────────────────────────

model ReagentInventory {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  branchId        String?   @map("branch_id")
  name            String
  manufacturer    String?
  lotNumber       String?   @map("lot_number")
  expiryDate      DateTime? @map("expiry_date")
  storageTemp     String?   @map("storage_temp") // 2-8C, -20C, RT
  currentStock    Float     @default(0) @map("current_stock")
  minStockLevel   Float     @default(0) @map("min_stock_level")
  unit            String    @default("units")
  linkedTestCodes Json      @default("[]") @map("linked_test_codes")
  supplier        String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, expiryDate])
  @@map("reagent_inventory")
}

model ReagentTransaction {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  reagentId       String    @map("reagent_id")
  txType          String    @map("tx_type") // IN|OUT|ADJUST|DISCARD
  quantity        Float
  balanceAfter    Float     @map("balance_after")
  referenceType   String?   @map("reference_type") // result_entry|manual|receive
  referenceId     String?   @map("reference_id")
  userId          String?   @map("user_id")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([reagentId])
  @@index([tenantId])
  @@map("reagent_transactions")
}

// ── Equipment Log ─────────────────────────────────────────────────────────

model EquipmentLog {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  branchId        String?   @map("branch_id")
  equipmentName   String    @map("equipment_name")
  model           String?
  serialNumber    String?   @map("serial_number")
  department      String?
  eventType       String    @map("event_type") // BREAKDOWN|MAINTENANCE|CALIBRATION|QC|INSTALLATION
  eventDate       DateTime  @map("event_date")
  resolvedAt      DateTime? @map("resolved_at")
  reportedBy      String?   @map("reported_by")
  description     String?
  downtimeHours   Float?    @map("downtime_hours")
  nextCalibration DateTime? @map("next_calibration")
  certificateUrl  String?   @map("certificate_url")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("equipment_logs")
}

// ── QC Results ────────────────────────────────────────────────────────────

model QcResult {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  branchId        String?   @map("branch_id")
  testCode        String    @map("test_code")
  analyserId      String?   @map("analyser_id")
  lotNumber       String?   @map("lot_number")
  controlLevel    String    @map("control_level") // NORMAL|ABNORMAL|CRITICAL
  expectedValue   Float     @map("expected_value")
  actualValue     Float     @map("actual_value")
  mean            Float?
  sd              Float?
  cvPercent       Float?    @map("cv_percent")
  westgardFlags   Json      @default("[]") @map("westgard_flags")
  isPass          Boolean   @default(true) @map("is_pass")
  runDate         DateTime  @map("run_date")
  technicianId    String?   @map("technician_id")
  capaId          String?   @map("capa_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([tenantId, testCode])
  @@index([tenantId, runDate])
  @@map("qc_results")
}

// ── Automation Rules (Revenue Engine) ─────────────────────────────────────

model DiagnosticAutomationRule {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  name            String
  testCode        String?   @map("test_code")   // which test triggers this
  triggerEvent    String    @map("trigger_event") // TEST_COMPLETED|ABNORMAL_RESULT|ANNIVERSARY
  conditionJson   Json?     @map("condition_json") // {ageMin, ageMax, valueAbove, valueBelow, gender}
  waitDays        Int       @default(90) @map("wait_days")
  templateCode    String    @map("template_code") // T15, T16, etc.
  messageText     String?   @map("message_text")
  isActive        Boolean   @default(true) @map("is_active")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  executions      DiagnosticAutomationExecution[]

  @@index([tenantId])
  @@map("diagnostic_automation_rules")
}

model DiagnosticAutomationExecution {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  ruleId          String    @map("rule_id")
  patientId       String    @map("patient_id")
  patientMobile   String    @map("patient_mobile")
  triggeredAt     DateTime  @map("triggered_at")
  scheduledFor    DateTime  @map("scheduled_for")
  sentAt          DateTime? @map("sent_at")
  response        String?   // BOOK_NOW|REMIND_LATER|STOP|NO_RESPONSE
  convertedOrderId String?  @map("converted_order_id")
  status          String    @default("PENDING") // PENDING|SENT|CONVERTED|OPTED_OUT

  rule            DiagnosticAutomationRule @relation(fields: [ruleId], references: [id])

  @@index([tenantId, status])
  @@index([scheduledFor])
  @@map("diagnostic_automation_executions")
}

// ── Tenant Wallets & Billing ───────────────────────────────────────────────

model TenantWallet {
  id                      String    @id @default(uuid())
  tenantId                String    @unique @map("tenant_id")
  subscriptionBalancePaise Int      @default(0) @map("subscription_balance_paise")
  waCredits               Float     @default(0) @map("wa_credits")    // fractional
  smsCredits              Int       @default(0) @map("sms_credits")
  storageGbPurchased      Float     @default(0) @map("storage_gb_purchased")
  autoRechargeWaEnabled   Boolean   @default(false) @map("auto_recharge_wa_enabled")
  autoRechargeWaThreshold Int       @default(500) @map("auto_recharge_wa_threshold")
  autoRechargeWaPackId    String?   @map("auto_recharge_wa_pack_id")
  autoRechargePmId        String?   @map("auto_recharge_pm_id") // payment method id
  updatedAt               DateTime  @updatedAt @map("updated_at")

  transactions            WalletTransaction[]

  @@map("tenant_wallets")
}

model WalletTransaction {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  walletId        String        @map("wallet_id")
  walletType      WalletType    @map("wallet_type")
  txType          WalletTxType  @map("tx_type")
  amount          Float
  balanceBefore   Float         @map("balance_before")
  balanceAfter    Float         @map("balance_after")
  referenceType   String?       @map("reference_type")
  referenceId     String?       @map("reference_id")
  description     String
  createdAt       DateTime      @default(now()) @map("created_at")

  wallet          TenantWallet  @relation(fields: [walletId], references: [id])

  @@index([tenantId, walletType])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model RechargePack {
  id              String    @id @default(uuid())
  packType        WalletType @map("pack_type")
  name            String
  creditsOrUnits  Float     @map("credits_or_units")
  priceInclGst    Int       @map("price_incl_gst")   // in paise
  priceExclGst    Int       @map("price_excl_gst")   // in paise
  gstRate         Float     @default(0.18) @map("gst_rate")
  isActive        Boolean   @default(true) @map("is_active")
  sortOrder       Int       @default(0) @map("sort_order")
  planRestriction Json?     @map("plan_restriction") // null = all plans
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("recharge_packs")
}

model HospibotInvoice {
  id              String    @id @default(uuid())
  invoiceNumber   String    @unique @map("invoice_number") // HB-INV-YYYY-MM-NNNN
  tenantId        String    @map("tenant_id")
  invoiceType     String    @map("invoice_type") // SUBSCRIPTION|WA_TOPUP|SMS_TOPUP|STORAGE|UPGRADE
  lineItems       Json      @map("line_items")
  subtotalPaise   Int       @map("subtotal_paise")
  gstPaise        Int       @map("gst_paise")
  totalPaise      Int       @map("total_paise")
  hospibotGstin   String?   @map("hospibot_gstin")
  tenantGstin     String?   @map("tenant_gstin")
  irn             String?
  paidAt          DateTime? @map("paid_at")
  paymentId       String?   @map("payment_id")
  pdfUrl          String?   @map("pdf_url")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("hospibot_invoices")
}

model RazorpayPayment {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  razorpayOrderId String    @unique @map("razorpay_order_id")
  razorpayPaymentId String? @unique @map("razorpay_payment_id")
  razorpaySignature String? @map("razorpay_signature")
  amountPaise     Int       @map("amount_paise")
  currency        String    @default("INR")
  packId          String?   @map("pack_id")
  walletType      WalletType? @map("wallet_type")
  status          String    @default("CREATED") // CREATED|CAPTURED|FAILED|REFUNDED
  failureReason   String?   @map("failure_reason")
  paymentMethod   String?   @map("payment_method") // upi|card|netbanking
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("razorpay_payments")
}

model SavedPaymentMethod {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  methodType      String    @map("method_type") // UPI_AUTOPAY|CARD
  razorpayToken   String?   @map("razorpay_token")
  mandateId       String?   @map("mandate_id")
  displayName     String    @map("display_name") // "GPay — 9876543210@okaxis"
  isDefault       Boolean   @default(false) @map("is_default")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("saved_payment_methods")
}

model MessageUsageLog {
  id              String          @id @default(uuid())
  tenantId        String          @map("tenant_id")
  branchId        String?         @map("branch_id")
  messageType     String          @map("message_type") // UTILITY|MARKETING|AUTHENTICATION|SERVICE
  templateCode    String?         @map("template_code")
  recipientMobile String          @map("recipient_mobile")
  direction       String          @default("OUTBOUND")
  creditsCharged  Float           @map("credits_charged")
  waDeliveryStatus String?        @map("wa_delivery_status") // SENT|DELIVERED|READ|FAILED
  failureReason   String?         @map("failure_reason")
  smsFallbackSent Boolean         @default(false) @map("sms_fallback_sent")
  labOrderId      String?         @map("lab_order_id")
  automationRuleId String?        @map("automation_rule_id")
  sentAt          DateTime        @default(now()) @map("sent_at")

  @@index([tenantId, messageType])
  @@index([tenantId, sentAt])
  @@map("message_usage_logs")
}

