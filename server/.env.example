# ══════════════════════════════════════════════════════════════════
# HOSPIBOT SERVER — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════

# ── Database ──
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── JWT ──
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRY=7d

# ── Server ──
PORT=4000
NODE_ENV=production
API_PREFIX=api/v1
FRONTEND_URL=https://hospibot-web.vercel.app

# ── Razorpay (Payment Gateway) ──
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxx

# ── WhatsApp (Meta Cloud API) ──
# These can also be configured per-tenant from Super Admin portal
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_VERIFY_TOKEN=hospibot-wa-verify

# ── SMS (MSG91 — default, switchable from Super Admin) ──
MSG91_AUTH_KEY=
MSG91_SENDER_ID=HSPBOT
MSG91_DLT_ENTITY_ID=

# ── Email (SMTP — default, switchable from Super Admin) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=HospiBot
SMTP_FROM_EMAIL=noreply@hospibot.in

# ── AWS S3 (File Storage — optional) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=hospibot-uploads
AWS_S3_REGION=ap-south-1

# ── Super Admin Credentials ──
SUPER_ADMIN_EMAIL=admin@hospibot.in
SUPER_ADMIN_PASSWORD=
