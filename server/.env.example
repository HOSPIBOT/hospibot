# ==========================================
# HOSPIBOT SERVER ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and fill in the values

# App
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Redis (Upstash)
REDIS_URL=redis://default:[PASSWORD]@[HOST]:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_REFRESH_EXPIRATION=7d

# WhatsApp Cloud API (Meta)
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=hospibot-webhook-verify-token

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=hospibot-storage

# Razorpay — see full config at bottom of this file
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google Cloud (Speech-to-Text) - Phase 5
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_CREDENTIALS=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Razorpay (Invoice payments + SaaS Subscription Billing)
# Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Razorpay Subscription Plans ──────────────────────────────────────────
# Create these plans in Razorpay Dashboard → Subscriptions → Plans
# Plan IDs must match what you create there:
#   plan_starter_monthly       ₹4,900/month
#   plan_growth_monthly        ₹9,900/month
#   plan_professional_monthly  ₹19,900/month
#   plan_enterprise_monthly    ₹49,900/month
#
# After creating plans in dashboard, set the IDs above in subscription.service.ts
# Webhook URL for Razorpay dashboard: https://api.hospibot.ai/api/v1/subscriptions/webhook/razorpay

# ABDM / ABHA Integration (Ayushman Bharat Health Account)
# Register at: https://sandbox.abdm.gov.in/
ABHA_CLIENT_ID=your_abha_client_id
ABHA_CLIENT_SECRET=your_abha_client_secret
ABDM_BASE_URL=https://healthidsbx.abdm.gov.in

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourhospital.com
SMTP_PASS=your_app_password

# SMS — MSG91 (India)
# Dashboard: https://msg91.com/
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=HSPBOT
MSG91_TEMPLATE_ID=your_template_id
